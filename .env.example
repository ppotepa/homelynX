# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Allowed Telegram users and command permissions are loaded from allowed-users.cfg.
# Example lines: "8153696940 ALL" or "@telegramUsername SAY".
# The first Telegram user who messages the bot is bootstrapped automatically when the file is empty.
TELEGRAM_ALLOWED_USERS=
TELEGRAM_ALLOWED_USERS_FILE=allowed-users.cfg
TELEGRAM_BOOTSTRAP_FIRST_USER=true
# Admin chat ID for notifications
TELEGRAM_ADMIN_CHAT_ID=
# Notification chat ID (can be same as admin)
TELEGRAM_NOTIFICATION_CHAT_ID=
# Dedicated bot tokens for the separate polling bots. Do not reuse the same token
# across multiple bot services.
SURV_TELEGRAM_BOT_TOKEN=
SURV_TELEGRAM_CHAT_ID=
SURV_TELEGRAM_MIN_SEVERITY=medium

# qBittorrent Configuration
QBIT_HOST=qbittorrent
QBIT_PORT=8080
QBIT_USERNAME=admin
QBIT_PASSWORD=
QBIT_HTTPS=false

# Jackett Configuration
JACKETT_HOST=jackett
JACKETT_PORT=9117
JACKETT_API_KEY=
JACKETT_HTTPS=false
# Public Jackett indexers configured automatically by install.sh.
# Only public/no-account indexers can be fully automated.
JACKETT_INDEXERS_PRESET=1337x,thepiratebay,limetorrents,torrentdownloads,torrentdownload,eztv,yts,nyaasi,therarbg,kickasstorrents-to,extratorrent-st,kickasstorrents-ws,knaben,magnetcat,torrentcore,uindex,internetarchive,torrentproject2
JACKETT_SEARCH_INDEXERS=1337x,thepiratebay,limetorrents,eztv,yts,nyaasi,therarbg,knaben,internetarchive
JACKETT_DISABLED_INDEXERS=magnetz,torrentgalaxyclone
JACKETT_TIMEOUT_SECONDS=15

# Download Paths
MEDIA_LIBRARY_PATH=/home/ppotepa/mediaserver
HOST_DOWNLOAD_PATH=/home/ppotepa/mediaserver/downloads
DOWNLOAD_PATH=/downloads
COMPLETED_PATH=/downloads/completed
TEMP_PATH=/downloads/incomplete
DOWNLOAD_MOVIES_PATH=/downloads/completed/movies
DOWNLOAD_TV_PATH=/downloads/completed/shows
DOWNLOAD_SHOWS_PATH=/downloads/completed/shows
DOWNLOAD_MUSIC_PATH=/downloads/completed/music
DOWNLOAD_GAMES_PATH=/downloads/completed/games
DOWNLOAD_SOFTWARE_PATH=/downloads/completed/software
DOWNLOAD_BOOKS_PATH=/downloads/completed/books
DOWNLOAD_ANIME_PATH=/downloads/completed/anime
DOWNLOAD_OTHER_PATH=/downloads/completed/other
TELEGRAM_MAX_UPLOAD_MB=50
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=1200
YTDLP_COOKIES_FILE=/app/cookies/facebook.txt

# Homelynx Portal
PORTAL_ENABLED=true
PORTAL_PORT=80
PORTAL_AUTH_ENABLED=true
PORTAL_USERNAME=admin
# Generated by install.sh in .env. Format: pbkdf2_sha256:iterations:salt:hash
PORTAL_PASSWORD_HASH=
PORTAL_SESSION_SECRET=
LLM_AUDIT_TOKEN=
LLM_AUDIT_RETENTION_DAYS=30
LLM_AUDIT_URL=http://127.0.0.1/api/llm/audit
LLM_PLANNER_MODEL=
LLM_RESPONDER_MODEL=
PORTAL_PUBLIC_URL=http://homelynx.zt/llm
PORTAL_LOCAL_URL=http://localhost/llm
PORTAL_ADMIN_URL=http://homelynx.zt/admin
BOT_NATURAL_LANGUAGE_ENABLED=true
BOT_NATURAL_LANGUAGE_TIMEOUT_SECONDS=45
BOT_NATURAL_LANGUAGE_PLANNER_NUM_PREDICT=192
BOT_NATURAL_LANGUAGE_RESPONDER_NUM_PREDICT=192
BOT_NATURAL_LANGUAGE_KEEP_ALIVE=-1
BOT_NATURAL_LANGUAGE_OUTPUT_FORMAT=schema
HOMELYNX_LLM_SYSTEM_PROMPT_PROFILE=compact
E2E_BENCHMARK_MODE=live
BOT_NATURAL_LANGUAGE_MIN_CONFIDENCE=0.45
BOT_QUERY_MAX_ITERATIONS=3
BOT_QUERY_LLM_CRITIC_ENABLED=true
BOT_QUERY_HUMANIZER_ENABLED=true
BOT_QUERY_TIMEOUT_SECONDS=10

# Media Library Server
# Jellyfin serves the downloaded media library over HTTP.
JELLYFIN_ENABLED=true
JELLYFIN_PORT=8096
JELLYFIN_CONFIG_PATH=./jellyfin-config
MEDIA_ORGANIZER_SOURCE=/home/ppotepa/mediaserver/downloads/completed
MEDIA_ORGANIZER_MODE=hardlink
MEDIA_ORGANIZER_MIN_CONFIDENCE=0.70
MEDIA_ORGANIZER_LLM_ENABLED=true
MEDIA_ORGANIZER_LLM_MODEL=qwen3:0.6b
MEDIA_ORGANIZER_LLM_URL=http://127.0.0.1:11434

# TTS Configuration
TTS_HOST=tts
TTS_PORT=5055
TTS_HTTPS=false
TTS_DEFAULT_LANGUAGE=auto
TTS_PLAYBACK_ENABLED=true
TTS_PLAYBACK_BACKEND=auto
TTS_PLAYBACK_DEVICE=JBL Go 4
TTS_PULSE_SINK=
TTS_PIPEWIRE_TARGET=
TTS_MAX_TEXT_CHARS=1000
TTS_PL_VOICE_NAME=pl_PL-meski_wg_glos-medium
TTS_PL_MODEL_URL=https://huggingface.co/WitoldG/polish_piper_models/resolve/main/pl_PL-meski_wg_glos-medium.onnx
TTS_PL_CONFIG_URL=https://huggingface.co/WitoldG/polish_piper_models/resolve/main/pl_PL-meski_wg_glos-medium.onnx.json

# Surveillance Configuration
SURV_HOST=surveillance
SURV_PORT=5060
SURV_CAMERA_DEVICE=/dev/v4l/by-id/usb-046d_HD_Pro_Webcam_C920-video-index0
SURV_AUDIO_DEVICE=sysdefault:CARD=C920
SURV_AUDIO_FILTER=highpass=f=120,lowpass=f=7000,afftdn=nf=-25,alimiter=limit=0.85
SURV_SEGMENT_SECONDS=5
SURV_RECORDER_WATCHDOG_SECONDS=20
SURV_RECORDER_RESTART_DELAY_SECONDS=3
SURV_SNAPSHOT_RAM_LIMIT_BYTES=1073741824
SURV_RETENTION_HOURS=24
SURV_EVENT_RETENTION_DAYS=14
SURV_INCIDENT_GAP_SECONDS=90
SURV_RECORD_VIDEO=true
SURV_RECORD_AUDIO=true
SURV_ANALYZER_WORKERS=2
SURV_SPEECH_RATIO_THRESHOLD=0.18
SURV_LOUD_PEAK_THRESHOLD=0.45
SURV_EVENT_GAP_SECONDS=25
SURV_NOTIFY_ENABLED=true
SURV_TRANSCRIBE_ENABLED=true
SURV_TRANSCRIBE_MODEL=small
SURV_TRANSCRIBE_LANGUAGE=auto
SURV_TRANSCRIBE_COMPUTE_TYPE=int8
SURV_TRANSCRIBE_BEAM_SIZE=5
SURV_TRANSCRIBE_VAD=true
SURV_TRANSCRIBE_VAD_MIN_SILENCE_MS=500
SURV_TRANSCRIBE_WORD_TIMESTAMPS=false
SURV_TRANSCRIBE_CONDITION_ON_PREVIOUS_TEXT=false
SURV_JOB_WORKERS=1
SURV_JOB_MAX_ATTEMPTS=3
SURV_JOB_POLL_SECONDS=1.0
SURV_JOB_DONE_RETENTION_HOURS=48
SURV_JOB_FAILED_RETENTION_HOURS=168
SURV_PREVIEW_GIF_ENABLED=true
SURV_PREVIEW_GIF_SPEED=5.0
SURV_PREVIEW_GIF_FPS=6
SURV_PREVIEW_GIF_WIDTH=480
SURV_PREVIEW_GIF_AUDIO_HEIGHT=84
SURV_PREVIEW_GIF_MAX_SOURCE_SECONDS=180
SURV_OPERATOR_SUMMARY_DEFAULT_HOURS=24
SURV_OPERATOR_SUMMARY_MAX_EVENTS=120
SURV_OPERATOR_SUMMARY_MAX_TRANSCRIPT_CHARS=14000
SURV_OPERATOR_SUMMARY_TIMEOUT_SECONDS=45
SURV_NOTIFY_MIN_INTERVAL_SECONDS=45
SURV_NOTIFY_BACKLOG_SUPPRESS_SECONDS=180
SURV_RECENT_SEGMENT_BUFFER=240
SURV_SPEECH_EXTENDED_SEGMENTS=2
SURV_NOISE_SPIKE_MULTIPLIER=2.4
SURV_DEVICE_ALERT_COOLDOWN_SECONDS=300
SURV_MOTION_ENABLED=true
SURV_FACE_ENABLED=true
SURV_PERSON_ENABLED=true
SURV_MOTION_DIFF_THRESHOLD=18
SURV_MOTION_MIN_RATIO=0.015
SURV_FACE_MIN_SIZE=64
SURV_PERSON_HOG_STRIDE=8
SURV_PERSON_MIN_CONFIDENCE=0.45
SURV_EVENT_TRIGGER_KINDS=PERSON_DETECTION,FACE_DETECTION
SURV_LLM_SUMMARIES_ENABLED=true
SURV_LLM_MIN_SEVERITY=medium
SURV_CPUS=2.0
SURV_MEM_LIMIT=2g

# Coordinate Input Configuration
# Android app sends locations to http://<server-ip>:5070/location with this API key.
# install.sh generates a real value in .env if this placeholder is present.
COORD_INPUT_API_KEY=change_me_coord_input_api_key
# Token from @BotFather for @potepa_home_coord_input_bot. Keep empty until created.
COORD_TELEGRAM_BOT_TOKEN=
# Optional; if empty, first Telegram chat messaging the coord bot is bootstrapped.
COORD_TELEGRAM_CHAT_ID=
COORD_TELEGRAM_ALLOWED_USERS=
COORD_TELEGRAM_BOOTSTRAP_CHAT=true
COORD_NOTIFY_ENABLED=false
COORD_NOTIFY_MIN_INTERVAL_SECONDS=60
COORD_NOTIFY_MIN_DISTANCE_METERS=25
COORD_HISTORY_LIMIT=5000
COORD_BOT_POLL_SECONDS=2
COORD_LLM_SUMMARY_ENABLED=true
COORD_LLM_MODEL=qwen3:0.6b
COORD_LLM_TIMEOUT_SECONDS=20
COORD_ANDROID_ARCHIVE_ENABLED=true
COORD_ANDROID_DIRECT_TELEGRAM=false
COORD_ANDROID_HIGH_POWER_GPS=false
COORD_START_TRACKING=true
COORD_INTERVAL_SECONDS=60
COORD_MIN_DISTANCE_METERS=25

# Local LLM Configuration
LLM_ENABLED=true
LLM_HOST=llm
LLM_PORT=11434
LLM_MODEL=qwen3:0.6b
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TRANSCRIPT_CHARS=1600
LLM_CPUS=8.0
LLM_MEM_LIMIT=12g
OLLAMA_KEEP_ALIVE=-1
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_MAX_QUEUE=64
OLLAMA_LOAD_TIMEOUT=10m

# ZeroTier Remote Access
# Optional. Set ZEROTIER_NETWORK_ID to join a private ZeroTier network during setup.
# Then authorize this machine in my.zerotier.com and connect from your phone through the ZeroTier app.
ZEROTIER_ENABLED=false
ZEROTIER_NETWORK_ID=
ZEROTIER_INSTALL_IF_MISSING=true
ZEROTIER_DNS_ENABLED=false
ZEROTIER_DNS_DOMAIN=homelynx.zt
ZEROTIER_DNS_SERVER_IP=

# Search Configuration
SEARCH_LIMIT=50
MIN_SEEDERS=1
SEARCH_TIMEOUT=30

# Application Configuration
COMPOSE_PROJECT_NAME=homelynx
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=/app/logs/homelynx.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Hot plugin folder (relative to project root)
PLUGIN_DIR=plugins/hot
